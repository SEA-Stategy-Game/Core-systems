; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Core"
run/main_scene="res://world.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
run/low_processor_mode_sleep_usec=0
config/icon="res://icon.svg"

[autoload]

Game="*res://Logic/Game.gd"
ActionGateway="*res://Logic/ActionGateway.gd"
TickManager="*res://Logic/TickManager.gd"
Server="*res://Logic/Server.gd"
DebugWindow="*res://UI/DebugWindow.tscn"
ResourceSpawner="*res://Entities/Map/Resource_spawner.gd"

[dotnet]

project/assembly_name="New Game Project"

[editor_plugins]

enabled=PackedStringArray()

